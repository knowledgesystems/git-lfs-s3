{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PublicReadSnapshot",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME/public/*"
    },
    {
      "Sid": "DenyPublicReadLFS",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME/lfs/*",
      "Condition": {
        "StringNotEquals": {
          "aws:PrincipalArn": "arn:aws:iam::YOUR_ACCOUNT_ID:role/github-lfs-lambda-role"
        }
      }
    }
  ]
}
